{
  "name": "@anclora/filestudio-local-agent",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "main": "./src/agent.ts",
  "scripts": {
    "dev": "tsx watch src/agent.ts",
    "build": "tsc -p tsconfig.json --outDir dist --noEmit false && node ../../scripts/build-local-agent.mjs",
    "start": "node dist/agent.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@anclora/filestudio-core": "workspace:*",
    "sharp": "^0.35.1",
    "yaml": "^2.9.0",
    "zod": "^4.4.3",
    "ulid": "^2.3.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "typescript": "^5",
    "tsx": "^4.19.4",
    "vitest": "^4.1.8"
  }
}
