{
  "name": "anclora-filestudio",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:vercel": "ANCLORA_FILESTUDIO_DEPLOYMENT_TARGET=vercel NEXT_PUBLIC_ANCLORA_FILESTUDIO_MODE=vercel-web NEXT_PUBLIC_ENABLE_BROWSER_DATA_CONVERSIONS=true ANCLORA_FILESTUDIO_ENABLE_SERVER_CONVERSIONS=false ANCLORA_FILESTUDIO_ENABLE_CLOUD_UPLOADS=false next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:engines": "vitest run --config vitest.engines.config.ts",
    "test:security": "vitest run --config vitest.security.config.ts",
    "test:operations": "vitest run --config vitest.operations.config.ts",
    "test:automation": "vitest run --config vitest.automation.config.ts",
    "test:background-removal": "vitest run --config vitest.background-removal.config.ts",
    "test:alpha-channel": "vitest run --config vitest.alpha-channel.config.ts",
    "test:vision-pack": "vitest run --config vitest.vision-pack.config.ts",
    "test:core": "vitest run --config vitest.core.config.ts",
    "test:sdk": "vitest run --config vitest.sdk.config.ts",
    "test:api": "pnpm --filter @anclora/filestudio-api test",
    "test:contracts": "pnpm test:nexus-contract",
    "test:desktop": "pnpm test",
    "test:openapi": "pnpm test:nexus-contract",
    "test:persistence": "pnpm --filter @anclora/filestudio-core test",
    "test:queue": "pnpm --filter @anclora/filestudio-worker test",
    "test:storage": "pnpm --filter @anclora/filestudio-worker test",
    "test:workers": "pnpm --filter @anclora/filestudio-worker test",
    "test:concurrency": "pnpm --filter @anclora/filestudio-worker test",
    "test:cleanup": "vitest run tests/unit/coordinated-cleanup.test.ts tests/unit/disk-space-check.test.ts",
    "test:auth": "pnpm --filter @anclora/filestudio-api test -- tests/auth.test.ts",
    "test:authorization": "pnpm --filter @anclora/filestudio-api test -- tests/auth.test.ts tests/agent.test.ts",
    "test:webhooks": "pnpm --filter @anclora/filestudio-api test -- tests/webhook.test.ts",
    "test:ssrf": "pnpm --filter @anclora/filestudio-api test -- tests/webhook.test.ts",
    "test:rate-limit": "pnpm --filter @anclora/filestudio-api test -- tests/observability.test.ts",
    "test:service:e2e": "pnpm --filter @anclora/filestudio-local-agent test -- tests/smoke.test.ts",
    "test:local-agent": "pnpm --filter @anclora/filestudio-local-agent test",
    "test:pairing": "pnpm --filter @anclora/filestudio-local-agent test -- tests/pairing.test.ts",
    "test:routing": "pnpm --filter @anclora/filestudio-nexus test -- tests/routing-policy.test.ts",
    "test:nexus-contract": "pnpm --filter @anclora/filestudio-nexus test -- tests/contract.test.ts",
    "test:privacy": "pnpm --filter @anclora/filestudio-local-agent test -- tests/consent.test.ts tests/credential-store.test.ts",
    "test:e2e": "playwright test",
    "test:vercel": "vitest run tests/vercel",
    "build:desktop": "next build",
    "build:service": "pnpm --filter @anclora/filestudio-api build",
    "build:local-agent": "pnpm --filter @anclora/filestudio-local-agent build",
    "build:portable:windows": "bash scripts/build-windows-portable.sh",
    "build:portable:linux": "bash scripts/build-linux-portable.sh",
    "verify:portable:windows": "bash scripts/verify-windows-portable-v2.sh",
    "verify:portable:linux": "bash scripts/verify-linux-portable.sh",
    "smoke:portable:windows": "bash scripts/smoke-windows-portable.sh",
    "smoke:portable:linux": "bash scripts/smoke-linux-portable.sh",
    "test:acceptance:fixtures": "node scripts/acceptance/generate-fixtures.mjs",
    "test:acceptance:api": "node scripts/acceptance/run-conversion-suite.mjs",
    "test:acceptance:linux": "bash scripts/acceptance/run-linux-portable-e2e.sh",
    "test:acceptance:windows": "bash scripts/acceptance/run-windows-portable-e2e.sh",
    "test:acceptance:compare": "node scripts/acceptance/compare-platform-results.mjs",
    "smoke:local-agent": "pnpm test:local-agent -- tests/smoke.test.ts",
    "smoke:service": "pnpm test:service:e2e",
    "generate:sbom": "node scripts/generate-sbom.mjs",
    "audit:licenses": "node scripts/audit-licenses.mjs",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "check:deps": "node scripts/check-dependencies.mjs",
    "verify:vercel": "ANCLORA_FILESTUDIO_DEPLOYMENT_TARGET=vercel NEXT_PUBLIC_ANCLORA_FILESTUDIO_MODE=vercel-web node scripts/verify-vercel-bundle.mjs",
    "deploy:vercel:preview": "vercel deploy",
    "deploy:vercel:production": "vercel deploy --prod",
    "cleanup": "node scripts/cleanup-temp.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "better-sqlite3": "^12.10.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "csv-parse": "^7.0.0",
    "csv-stringify": "^6.8.0",
    "fast-xml-parser": "^5.8.0",
    "file-type": "^22.0.1",
    "lucide-react": "^1.18.0",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.11.0",
    "sharp": "^0.35.1",
    "smol-toml": "^1.6.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/csv-parse": "^1.2.5",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sharp": "^0.32.0",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  },
  "pnpm": {
    "overrides": {
      "postcss": "8.5.10"
    },
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
