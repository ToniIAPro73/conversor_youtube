# Anclora FileStudio — Desktop mode configuration
# Copy to .env.local and adjust values for your environment.
# For Service mode variables see docs/implementation/anclora-filestudio-service-api/deployment-vps.md

APP_NAME=Anclora FileStudio
APP_VERSION=0.2.0

# Desktop: mode is always "desktop" (no value needed for local runs)
# ANCLORA_FILESTUDIO_MODE=desktop

# Deployment targets:
# - desktop: full local conversion runtime.
# - vercel: Web-only browser-safe mode, no server conversions.
# - service: future VPS API/worker profile.
ANCLORA_FILESTUDIO_DEPLOYMENT_TARGET=desktop
NEXT_PUBLIC_ANCLORA_FILESTUDIO_MODE=desktop
NEXT_PUBLIC_ENABLE_BROWSER_DATA_CONVERSIONS=false
ANCLORA_FILESTUDIO_ENABLE_SERVER_CONVERSIONS=true
ANCLORA_FILESTUDIO_ENABLE_CLOUD_UPLOADS=false
NEXT_PUBLIC_WINDOWS_DOWNLOAD_URL=
NEXT_PUBLIC_LINUX_DOWNLOAD_URL=
NEXT_PUBLIC_SUPPORT_URL=
NEXT_PUBLIC_FILESTUDIO_SERVICE_URL=

MEDIA_TEMP_DIR=.tmp/media
YTDLP_BINARY=yt-dlp
FFMPEG_BINARY=ffmpeg
FFPROBE_BINARY=ffprobe

MAX_VIDEO_DURATION_SECONDS=7200
MAX_CONCURRENT_JOBS=2
MAX_ACTIVE_JOBS_PER_CLIENT=1
METADATA_TIMEOUT_SECONDS=30
CONVERSION_TIMEOUT_SECONDS=1200
JOB_TTL_MINUTES=60
DOWNLOAD_TOKEN_TTL_MINUTES=15

RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_METADATA_REQUESTS=10
RATE_LIMIT_MAX_JOB_REQUESTS=3
