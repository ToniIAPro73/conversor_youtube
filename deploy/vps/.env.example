# Anclora FileStudio Service — VPS environment variables
# Copy to .env and fill in your values. Never commit .env to git.

# Public URL (used in links returned by the API)
PUBLIC_BASE_URL=https://filestudio.yourdomain.com
PUBLIC_DOMAIN=filestudio.yourdomain.com

# Caddy ACME
CADDY_ACME_EMAIL=admin@yourdomain.com

# PostgreSQL — inject via your secret manager
POSTGRES_PASSWORD=

# Redis — inject via your secret manager
REDIS_PASSWORD=

# Full DSN (include the postgres password above)
DATABASE_URL=postgres://filestudio:<postgres-password>@postgres:5432/filestudio

# JWT issuer (identifies this service instance)
JWT_ISSUER=https://filestudio.yourdomain.com

# Worker concurrency (tune to CPU cores - 1)
WORKER_CONCURRENCY=4
