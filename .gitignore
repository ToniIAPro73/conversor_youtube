# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# tmp
.tmp/

# SQLite database files (created at runtime; persisted locally, not in git)
/data/*.sqlite
/data/*.sqlite-shm
/data/*.sqlite-wal

# Windows portable distribution — build cache, staging, and output artifacts
scripts/.cache/
scripts/.staging/
scripts/Link2Media-Windows-x64.zip
scripts/Link2Media-Windows-x64.zip.sha256

# Distribution artifacts (large binaries — do not commit)
dist/
SBOM.cdx.json

MEMORY.md