{
  "$schema": "https://anclora.dev/schemas/toolchain-lock/v1",
  "lockedAt": "2026-06-16",
  "lockedBy": "anclora-filestudio",
  "tools": [
    {
      "id": "node",
      "displayName": "Node.js",
      "version": ">=20.0.0",
      "platform": "all",
      "arch": "x64",
      "sourceUrl": "https://nodejs.org/dist/",
      "sha256": null,
      "license": "MIT",
      "licenseUrl": "https://github.com/nodejs/node/blob/main/LICENSE",
      "binaryRelativePath": "runtime/node",
      "versionArgs": ["--version"],
      "versionPattern": "v(\\d+\\.\\d+\\.\\d+)",
      "requiredFor": ["runtime"],
      "redistribution": "bundled",
      "notes": "Bundled in portable distribution. Version >= 20 required."
    },
    {
      "id": "ffmpeg",
      "displayName": "FFmpeg",
      "version": "4.4.2",
      "platform": "linux",
      "arch": "x64",
      "sourceUrl": "https://ffmpeg.org/download.html",
      "sha256": null,
      "license": "GPL-2.0-or-later",
      "licenseUrl": "https://ffmpeg.org/legal.html",
      "binaryRelativePath": "tools/ffmpeg/bin/ffmpeg",
      "versionArgs": ["-version"],
      "versionPattern": "ffmpeg version (\\S+)",
      "requiredFor": ["audio", "video", "gif", "thumbnail", "subtitle"],
      "redistribution": "bundled",
      "notes": "GPL build. Requires source code link or inclusion in distribution."
    },
    {
      "id": "ffprobe",
      "displayName": "FFprobe",
      "version": "4.4.2",
      "platform": "linux",
      "arch": "x64",
      "sourceUrl": "https://ffmpeg.org/download.html",
      "sha256": null,
      "license": "GPL-2.0-or-later",
      "licenseUrl": "https://ffmpeg.org/legal.html",
      "binaryRelativePath": "tools/ffmpeg/bin/ffprobe",
      "versionArgs": ["-version"],
      "versionPattern": "ffprobe version (\\S+)",
      "requiredFor": ["media-analysis"],
      "redistribution": "bundled",
      "notes": "Distributed alongside FFmpeg."
    },
    {
      "id": "ytdlp",
      "displayName": "yt-dlp",
      "version": "latest-stable",
      "platform": "all",
      "arch": "x64",
      "sourceUrl": "https://github.com/yt-dlp/yt-dlp/releases/latest",
      "sha256": null,
      "license": "Unlicense",
      "licenseUrl": "https://github.com/yt-dlp/yt-dlp/blob/master/LICENSE",
      "binaryRelativePath": "tools/ytdlp/yt-dlp",
      "versionArgs": ["--version"],
      "versionPattern": "(\\d{4}\\.\\d{2}\\.\\d{2})",
      "requiredFor": ["youtube-download"],
      "redistribution": "bundled",
      "notes": "Update frequently — YouTube changes API. Use ACTUALIZAR_YTDLP.bat."
    },
    {
      "id": "qpdf",
      "displayName": "QPDF",
      "version": "10.6.3",
      "platform": "linux",
      "arch": "x64",
      "sourceUrl": "https://github.com/qpdf/qpdf/releases",
      "sha256": null,
      "license": "Apache-2.0",
      "licenseUrl": "https://github.com/qpdf/qpdf/blob/main/LICENSE.txt",
      "binaryRelativePath": "tools/qpdf/bin/qpdf",
      "versionArgs": ["--version"],
      "versionPattern": "qpdf version (\\d+\\.\\d+\\.\\d+)",
      "requiredFor": ["pdf"],
      "redistribution": "bundled",
      "notes": "Apache-2.0 — freely redistributable."
    },
    {
      "id": "sevenzip",
      "displayName": "7-Zip",
      "version": "26.01",
      "platform": "linux",
      "arch": "x64",
      "sourceUrl": "https://7-zip.org/download.html",
      "sha256": null,
      "license": "LGPL-2.1",
      "licenseUrl": "https://7-zip.org/license.txt",
      "binaryRelativePath": "tools/7zip/7zz",
      "versionArgs": ["i"],
      "versionPattern": "7-Zip \\([az]\\) (\\d+\\.\\d+)",
      "requiredFor": ["archive"],
      "redistribution": "bundled",
      "notes": "LGPL core — binary redistribution allowed. unRAR code not included."
    },
    {
      "id": "pandoc",
      "displayName": "Pandoc",
      "version": "2.9.2.1",
      "platform": "linux",
      "arch": "x64",
      "sourceUrl": "https://github.com/jgm/pandoc/releases",
      "sha256": null,
      "license": "GPL-2.0-or-later",
      "licenseUrl": "https://github.com/jgm/pandoc/blob/main/COPYING.md",
      "binaryRelativePath": "tools/pandoc/bin/pandoc",
      "versionArgs": ["--version"],
      "versionPattern": "pandoc (\\d+\\.\\d+\\.\\d+)",
      "requiredFor": ["document"],
      "redistribution": "optional-pack",
      "notes": "GPL-2. Binary redistribution with notice. Included in Office Pack."
    },
    {
      "id": "libreoffice",
      "displayName": "LibreOffice",
      "version": "7.3.7.2",
      "platform": "linux",
      "arch": "x64",
      "sourceUrl": "https://www.libreoffice.org/download/download-libreoffice/",
      "sha256": null,
      "license": "LGPL-3.0",
      "licenseUrl": "https://www.libreoffice.org/about-us/licenses/",
      "binaryRelativePath": "tools/libreoffice/program/soffice",
      "versionArgs": ["--version"],
      "versionPattern": "LibreOffice (\\d+\\.\\d+\\.\\d+)",
      "requiredFor": ["office-to-pdf", "office-conversion"],
      "redistribution": "optional-pack",
      "notes": "LGPL-3. Large footprint (~300 MB). Included in Office Pack."
    },
    {
      "id": "calibre",
      "displayName": "Calibre",
      "version": "9.9.0",
      "platform": "linux",
      "arch": "x64",
      "sourceUrl": "https://calibre-ebook.com/download_linux",
      "sha256": null,
      "license": "GPL-3.0",
      "licenseUrl": "https://github.com/kovidgoyal/calibre/blob/master/LICENSE",
      "binaryRelativePath": "tools/calibre/calibredb",
      "versionArgs": ["--version"],
      "versionPattern": "calibre (\\d+\\.\\d+\\.\\d+)",
      "requiredFor": ["ebook"],
      "redistribution": "optional-pack",
      "notes": "GPL-3. Included in Ebook Pack. Not in Core distribution."
    },
    {
      "id": "tesseract",
      "displayName": "Tesseract OCR",
      "version": "4.1.1",
      "platform": "linux",
      "arch": "x64",
      "sourceUrl": "https://github.com/tesseract-ocr/tesseract",
      "sha256": null,
      "license": "Apache-2.0",
      "licenseUrl": "https://github.com/tesseract-ocr/tesseract/blob/main/LICENSE",
      "binaryRelativePath": "tools/tesseract/bin/tesseract",
      "versionArgs": ["--version"],
      "versionPattern": "tesseract (\\d+\\.\\d+\\.\\d+)",
      "requiredFor": ["ocr-image", "ocr-pdf"],
      "redistribution": "bundled",
      "notes": "Apache-2.0 — freely redistributable. Requires language packs."
    },
    {
      "id": "tesseract-spa",
      "displayName": "Tesseract — datos español",
      "version": "4.1.0",
      "platform": "linux",
      "arch": "all",
      "sourceUrl": "https://github.com/tesseract-ocr/tessdata_fast",
      "sha256": null,
      "license": "Apache-2.0",
      "licenseUrl": "https://github.com/tesseract-ocr/tessdata_fast/blob/main/LICENSE",
      "binaryRelativePath": "tools/tesseract/tessdata/spa.traineddata",
      "versionArgs": null,
      "versionPattern": null,
      "requiredFor": ["ocr-spa"],
      "redistribution": "bundled",
      "notes": "Apache-2.0 — freely redistributable."
    },
    {
      "id": "tesseract-eng",
      "displayName": "Tesseract — datos inglés",
      "version": "4.1.0",
      "platform": "linux",
      "arch": "all",
      "sourceUrl": "https://github.com/tesseract-ocr/tessdata_fast",
      "sha256": null,
      "license": "Apache-2.0",
      "licenseUrl": "https://github.com/tesseract-ocr/tessdata_fast/blob/main/LICENSE",
      "binaryRelativePath": "tools/tesseract/tessdata/eng.traineddata",
      "versionArgs": null,
      "versionPattern": null,
      "requiredFor": ["ocr-eng"],
      "redistribution": "bundled",
      "notes": "Apache-2.0 — freely redistributable."
    },
    {
      "id": "poppler",
      "displayName": "Poppler (pdftoppm)",
      "version": "22.02.0",
      "platform": "linux",
      "arch": "x64",
      "sourceUrl": "https://poppler.freedesktop.org/",
      "sha256": null,
      "license": "GPL-2.0",
      "licenseUrl": "https://gitlab.freedesktop.org/poppler/poppler/-/blob/master/COPYING",
      "binaryRelativePath": "tools/poppler/bin/pdftoppm",
      "versionArgs": ["-v"],
      "versionPattern": "pdftoppm version (\\d+\\.\\d+\\.\\d+)",
      "requiredFor": ["ocr-pdf", "pdf-to-image"],
      "redistribution": "optional-pack",
      "notes": "GPL-2. Required for PDF OCR pipeline. Included in OCR Pack."
    }
  ]
}
